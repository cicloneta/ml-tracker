<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ML Price Tracker - V2</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0b0d14;--panel:#111420;--card:#161926;--card2:#1c2030;
  --b1:#232740;--b2:#2c3154;
  --acc:#7c6ff7;--acl:#a89ef9;
  --up:#22c55e;--up2:#4ade80;--upg:rgba(34,197,94,.14);
  --dn:#ef4444;--dn2:#f87171;--dng:rgba(239,68,68,.14);
  --tx:#dde1f5;--sub:#8890b0;--mt:#4a5070;
  --mono:'IBM Plex Mono',monospace;
}
body{background:var(--bg);color:var(--tx);font-family:'Inter',sans-serif;min-height:100vh}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 70% 40% at 50% 0%,rgba(124,111,247,.1),transparent)}
.app{position:relative;z-index:1;display:flex;flex-direction:column;min-height:100vh}

/* TOPBAR */
.topbar{display:flex;align-items:center;gap:14px;padding:16px 24px;
  border-bottom:1px solid var(--b1);background:rgba(17,20,32,.9);
  backdrop-filter:blur(12px);position:sticky;top:0;z-index:100}
.brand{display:flex;align-items:center;gap:10px;flex:1}
.bico{width:36px;height:36px;border-radius:9px;
  background:linear-gradient(135deg,var(--acc),var(--acl));
  display:grid;place-items:center;font-size:16px;flex-shrink:0;
  box-shadow:0 0 18px rgba(124,111,247,.4)}
.bname{font-size:1rem;font-weight:800;letter-spacing:-.3px}
.bsub{font-size:.62rem;color:var(--sub);font-family:var(--mono);margin-top:1px}
.tstats{display:flex;gap:8px}
.ts{background:var(--panel);border:1px solid var(--b1);border-radius:8px;
  padding:5px 12px;text-align:center;min-width:54px}
.ts-v{font-size:.95rem;font-weight:700;font-family:var(--mono);line-height:1}
.ts-v.a{color:var(--acl)}.ts-v.u{color:var(--up2)}.ts-v.d{color:var(--dn2)}

/* LAYOUT */
.body{display:flex;flex:1}
.sidebar{width:272px;flex-shrink:0;background:var(--panel);border-right:1px solid var(--b1);
  display:flex;flex-direction:column;overflow-y:auto;padding:16px 14px 20px}
.main{flex:1;padding:20px 22px 60px;overflow-y:auto}

/* SIDEBAR COMPONENTS */
.slbl{font-size:.6rem;font-weight:700;letter-spacing:1.8px;color:var(--mt);
  text-transform:uppercase;margin-bottom:7px}
.sta{width:100%;background:var(--bg);border:1.5px solid var(--b2);border-radius:9px;
  padding:10px 12px;font-family:var(--mono);font-size:.74rem;color:var(--tx);
  outline:none;resize:none;min-height:86px;line-height:1.65;
  transition:border-color .2s;margin-bottom:7px}
.sta:focus{border-color:var(--acc)}
.sta::placeholder{color:var(--mt)}
.sbtn{width:100%;padding:10px;border-radius:8px;border:none;
  background:linear-gradient(135deg,var(--acc),var(--acl));color:#fff;
  font-family:'Inter',sans-serif;font-weight:600;font-size:.8rem;
  cursor:pointer;transition:all .15s}
.sbtn:hover{box-shadow:0 4px 18px rgba(124,111,247,.45);transform:translateY(-1px)}
.sdiv{display:flex;align-items:center;gap:10px;margin:14px 0 8px;color:var(--mt);font-size:.63rem}
.sdiv::before,.sdiv::after{content:'';flex:1;height:1px;background:var(--b1)}

/* DRAG & DROP EXCEL */
.xz{border:2px dashed var(--b2);border-radius:10px;padding:13px 10px;
  text-align:center;cursor:pointer;position:relative;transition:all .2s;background:var(--bg)}
.xz:hover,.xz.drag{border-color:var(--acc);background:rgba(124,111,247,.06)}
.xz input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.xz-ic{font-size:1.4rem;margin-bottom:3px}
.xz-t{font-size:.73rem;font-weight:600;color:var(--sub)}
.xz-s{font-size:.62rem;color:var(--mt);margin-top:3px}
.xz-s b{color:var(--acl)}

#xprev{background:var(--bg);border:1px solid var(--b1);border-radius:9px;overflow:hidden;margin-top:8px}
.xph{display:flex;align-items:center;justify-content:space-between;
  padding:7px 12px;border-bottom:1px solid var(--b1)}
.xph span{font-size:.7rem;font-weight:600;color:var(--sub)}
.xcnt{font-family:var(--mono);font-size:.63rem;
  background:rgba(124,111,247,.15);color:var(--acl);border-radius:4px;padding:2px 7px}
.xwrap{max-height:110px;overflow-y:auto}
.xt{width:100%;border-collapse:collapse;font-size:.66rem;font-family:var(--mono)}
.xt td{padding:4px 12px;border-bottom:1px solid rgba(35,39,64,.5);color:var(--sub)}
.xt td:first-child{color:var(--acl);font-weight:600}
.xt tr:last-child td{border-bottom:none}
.xacts{display:flex;gap:6px;padding:8px 12px;border-top:1px solid var(--b1)}
.xb{padding:5px 11px;border-radius:6px;border:none;font-family:'Inter',sans-serif;
  font-weight:600;font-size:.69rem;cursor:pointer;transition:all .12s}
.xb-ok{background:rgba(34,197,94,.1);color:var(--up2);border:1px solid rgba(34,197,94,.2)}
.xb-no{background:transparent;color:var(--mt);border:1px solid var(--b2)}

/* CONTROLS */
.sctrl{margin-top:auto;padding-top:14px;border-top:1px solid var(--b1)}
.sr{display:flex;align-items:center;gap:8px;margin-bottom:9px}
.sr-l{font-size:.7rem;color:var(--sub);flex:1}
.isel{background:var(--bg);border:1.5px solid var(--b2);border-radius:7px;
  padding:5px 8px;color:var(--tx);font-family:var(--mono);font-size:.7rem;outline:none}
.lpill{display:flex;align-items:center;gap:6px;font-size:.7rem;color:var(--up2);margin-bottom:8px}
.dot{width:6px;height:6px;border-radius:50%;background:var(--up2);
  animation:blink 1.5s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.sdng{width:100%;padding:8px;border-radius:7px;background:transparent;color:var(--dn2);
  border:1px solid rgba(239,68,68,.22);font-family:'Inter',sans-serif;
  font-weight:600;font-size:.73rem;cursor:pointer;transition:all .12s}
.sdng:hover{background:var(--dng)}

/* MAIN DASHBOARD */
.mhdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px}
.mhdr h2{font-size:1.05rem;font-weight:700}
.mhdr p{font-size:.7rem;color:var(--sub);margin-top:2px}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(285px,1fr));gap:14px}

/* PRODUCT CARD */
.pcard{background:var(--card);border:1px solid var(--b1);border-radius:14px;
  overflow:hidden;transition:border-color .35s,box-shadow .35s;position:relative}
.pcard::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--b1);transition:background .35s;pointer-events:none}
.pcard.up{border-color:rgba(34,197,94,.28);box-shadow:0 0 22px var(--upg)}
.pcard.up::after{background:linear-gradient(90deg,var(--up),var(--up2))}
.pcard.dn{border-color:rgba(239,68,68,.28);box-shadow:0 0 22px var(--dng)}
.pcard.dn::after{background:linear-gradient(90deg,var(--dn),var(--dn2))}

.pb{padding:14px 16px}
.pt{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.ptag{font-family:var(--mono);font-size:.61rem;font-weight:600;
  background:rgba(124,111,247,.12);color:var(--acl);
  border-radius:5px;padding:3px 8px;border:1px solid rgba(124,111,247,.18)}
.pacts{display:flex;gap:1px}
.pib{background:transparent;border:none;cursor:pointer;color:var(--mt);
  font-size:.85rem;padding:4px 6px;border-radius:5px;transition:all .12s;line-height:1}
.pib:hover{color:var(--acl);background:rgba(124,111,247,.1)}
.pib.x:hover{color:var(--dn2);background:var(--dng)}

.prow{display:flex;gap:11px;align-items:flex-start;margin-bottom:12px}
.pimg{width:64px;height:64px;object-fit:contain;border-radius:8px;
  border:1px solid var(--b2);background:var(--card2);flex-shrink:0}
.pph{width:64px;height:64px;border-radius:8px;background:var(--card2);
  border:1px solid var(--b2);display:grid;place-items:center;font-size:1.3rem;flex-shrink:0}
.pinf{flex:1;min-width:0}
.ptit{font-size:.82rem;font-weight:600;line-height:1.4;margin-bottom:5px;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.pmeta{display:flex;flex-wrap:wrap;gap:4px}
.mtag{font-size:.59rem;background:var(--card2);border:1px solid var(--b2);
  border-radius:4px;padding:2px 6px;color:var(--sub);font-family:var(--mono)}

.pblock{background:var(--card2);border:1px solid var(--b2);
  border-radius:10px;padding:12px 13px;margin-bottom:10px}
.pmain{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:3px}
.pnum{font-size:1.55rem;font-weight:800;font-family:var(--mono);
  line-height:1;letter-spacing:-.5px;transition:color .3s}
.pnum.n{color:var(--tx)}
.pnum.u{color:var(--up2);text-shadow:0 0 14px rgba(74,222,128,.25)}
.pnum.d{color:var(--dn2);text-shadow:0 0 14px rgba(248,113,113,.25)}
.pcur{font-size:.61rem;color:var(--mt);font-family:var(--mono);align-self:flex-end;margin-bottom:1px}
.pbdg{display:inline-flex;align-items:center;gap:3px;border-radius:5px;
  padding:2px 7px;font-size:.66rem;font-weight:700;font-family:var(--mono)}
.pbdg.u{background:rgba(34,197,94,.1);color:var(--up2);border:1px solid rgba(34,197,94,.2)}
.pbdg.d{background:rgba(239,68,68,.1);color:var(--dn2);border:1px solid rgba(239,68,68,.2)}
.pts{font-size:.59rem;color:var(--mt);font-family:var(--mono);margin-top:2px}

.pg{display:flex;align-items:center;gap:7px;font-size:.59rem;
  font-family:var(--mono);color:var(--mt);margin-bottom:10px}
.pgbg{flex:1;height:2px;background:var(--b1);border-radius:99px;overflow:hidden}
.pgf{height:100%;background:linear-gradient(90deg,var(--acc),var(--acl));
  border-radius:99px;transition:width .9s linear}

/* ERROR MESSAGE */
.perr{font-size:.7rem;color:var(--dn2);padding:8px 0;line-height:1.6;word-break:break-word;
  background:var(--dng);border-radius:8px;padding:10px;border:1px solid rgba(239,68,68,0.2)}

/* TOASTS */
.toasts{position:fixed;bottom:20px;right:20px;display:flex;flex-direction:column;
  gap:7px;z-index:9999;max-width:290px}
.toast{background:var(--card);border:1px solid var(--b2);border-radius:9px;
  padding:10px 14px;font-size:.75rem;box-shadow:0 8px 28px rgba(0,0,0,.5);
  animation:tin .25s ease}
.toast.ok{border-left:3px solid var(--up2)}
.toast.err{border-left:3px solid var(--dn2)}
@keyframes tin{from{opacity:0;transform:translateX(12px)}to{opacity:1;transform:none}}

/* HELPERS */
.hidden{display:none!important}
.sk{background:linear-gradient(90deg,var(--card2) 25%,var(--b2) 50%,var(--card2) 75%);
  background-size:200% 100%;animation:shim 1.3s infinite;border-radius:7px}
@keyframes shim{0%{background-position:200% 0}100%{background-position:-200% 0}}

@media(max-width:660px){
  .body{flex-direction:column}
  .sidebar{width:100%;border-right:none;border-bottom:1px solid var(--b1)}
  .tstats{display:none}
}
</style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <div class="brand">
      <div class="bico">🛒</div>
      <div>
        <div class="bname">ML Price Tracker</div>
        <div class="bsub">mercadolibre argentina · stealth v2</div>
      </div>
    </div>
    <div class="tstats">
      <div class="ts"><div class="ts-v a" id="tsT">0</div><div class="ts-l">Total</div></div>
      <div class="ts"><div class="ts-v u" id="tsU">0</div><div class="ts-l">Subieron</div></div>
      <div class="ts"><div class="ts-v d" id="tsD">0</div><div class="ts-l">Bajaron</div></div>
    </div>
  </div>

  <div class="body">
    <aside class="sidebar">
      <div class="slbl">Publicaciones</div>
      <textarea id="inp" class="sta" placeholder="IDs (MLA...) o Links"></textarea>
      <button class="sbtn" onclick="handleAdd()">+ Monitorear</button>

      <div class="sdiv">Excel</div>
      <div class="xz" id="xz" ondragover="dOv(event)" ondragleave="dLv()" ondrop="dDr(event)">
        <input type="file" id="xf" accept=".xlsx,.xls,.csv" onchange="xSel(event)"/>
        <div class="xz-ic">📊</div>
        <div class="xz-t">Cargar archivo</div>
      </div>

      <div id="xprev" class="xprev hidden">
        <div class="xph"><span id="xnm"></span><span class="xcnt" id="xcnt">0</span></div>
        <div class="xacts">
          <button class="xb xb-ok" onclick="xImp()">Importar</button>
          <button class="xb xb-no" onclick="xClr()">Borrar</button>
        </div>
      </div>

      <div class="sctrl">
        <div class="lpill hidden" id="lpill"><span class="dot"></span><span id="ln">0</span></div>
        <div class="sr">
          <span class="sr-l">Ciclo</span>
          <select class="isel" id="isel" onchange="iCh()">
            <option value="60" selected>1 min</option>
            <option value="300">5 min</option>
          </select>
        </div>
        <button class="sdng hidden" id="stopBtn" onclick="stopAll()">Limpiar Dashboard</button>
      </div>
    </aside>

    <main class="main">
      <div id="empty" style="text-align:center;padding-top:100px;color:var(--mt)">
        <h3>Sin publicaciones</h3>
        <p>Pegá un MLA para empezar</p>
      </div>
      <div id="grid" class="grid"></div>
    </main>
  </div>
</div>
<div class="toasts" id="toasts"></div>

<script>
const G = { m: {}, sec: 60 };

// ══════════════════════════════
// FETCH MEJORADO - STEALTH MODE
// ══════════════════════════════
async function fetchML(rawId) {
  const id = rawId.replace(/^(ML[A-Z]+)-?(\d+)$/i,'$1$2').toUpperCase();
  const targetUrl = `https://api.mercadolibre.com/items/${id}`;
  
  // Usamos un proxy que suele estar menos filtrado
  const proxyUrl = `https://corsproxy.io/?${encodeURIComponent(targetUrl)}`;

  try {
    const resp = await fetch(proxyUrl, {
      method: 'GET',
      referrerPolicy: "no-referrer", // OCULTA EL ORIGEN (GitHub)
      headers: {
        'Accept': 'application/json'
      }
    });

    if (!resp.ok) {
        if(resp.status === 403) throw new Error("Acceso Restringido (403). ML bloqueó este proxy.");
        throw new Error(`Error ${resp.status}`);
    }

    const d = await resp.json();

    if (d.error) throw new Error(d.message || d.error);
    if (!d.title) throw new Error("Producto no encontrado");

    let thumb = d.thumbnail || '';
    if (d.pictures && d.pictures[0]) thumb = d.pictures[0].secure_url || d.pictures[0].url || thumb;
    thumb = thumb.replace(/-[A-Z]\.(jpg|webp|png)/i, '-O.$1');

    return { 
      title: d.title, 
      price: d.price, 
      currency: d.currency_id, 
      thumbnail: thumb,
      stock: d.available_quantity ?? 0 
    };
  } catch (err) {
    throw err;
  }
}

// ══════════════════════════════
// LÓGICA DE MONITOR
// ══════════════════════════════
async function go(id) {
  const s = G.m[id]; if(!s) return;
  s.loading = true; s.err = null; draw(id);
  
  try {
    const d = await fetchML(id);
    const prev = s.prevP;
    s.st = prev === null ? 'neutral' : (d.price > prev ? 'up' : (d.price < prev ? 'dn' : 'neutral'));
    s.prevP = d.price;
    s.data = d;
    s.hist.unshift({ts: Date.now(), p: d.price, c: d.currency});
    if(s.hist.length > 20) s.hist.pop();
  } catch(e) {
    s.err = e.message;
    console.error("Error en " + id, e);
  } finally {
    s.loading = false;
    draw(id);
    updStats();
  }
}

function draw(id) {
  const s = G.m[id], el = document.getElementById('c'+id);
  if(!el) return;
  el.className = 'pcard ' + s.st;
  
  let content = '';
  if(s.loading && !s.data) {
    content = '<div class="pb"><div class="sk" style="height:100px"></div></div>';
  } else if(s.err && !s.data) {
    content = `<div class="pb"><span class="ptag">${id}</span><div class="perr">⚠️ ${s.err}</div><button onclick="go('${id}')" class="sbtn" style="margin-top:10px">Reintentar</button></div>`;
  } else if(s.data) {
    const pc = s.st === 'up' ? 'u' : (s.st === 'dn' ? 'd' : 'n');
    content = `
      <div class="pb">
        <div class="pt"><span class="ptag">${id}</span><button class="pib x" onclick="rm('${id}')">✕</button></div>
        <div class="prow">
          <img src="${s.data.thumbnail}" class="pimg" alt=""/>
          <div class="pinf"><div class="ptit">${s.data.title}</div><div class="pmeta"><span class="mtag">Stock: ${s.data.stock}</span></div></div>
        </div>
        <div class="pblock">
          <div class="pmain">
            <span class="pnum ${pc}">${s.data.price.toLocaleString('es-AR', {style:'currency', currency:s.data.currency})}</span>
          </div>
          <div class="pts">Actualizado: ${new Date(s.hist[0].ts).toLocaleTimeString()}</div>
        </div>
        <div class="pg"><div class="pgbg"><div class="pgf" style="width:${(s.cd/s.sec)*100}%"></div></div><span>${s.cd}s</span></div>
      </div>
    `;
  }
  el.innerHTML = content;
}

// ══════════════════════════════
// CORE APP
// ══════════════════════════════
function add(id) {
  if(G.m[id]) return;
  G.m[id] = { data: null, hist: [], st: 'neutral', prevP: null, err: null, loading: false, cd: G.sec, sec: G.sec };
  const d = document.createElement('div'); d.id = 'c'+id; d.className = 'pcard';
  document.getElementById('grid').appendChild(d);
  go(id);
  G.m[id].ci = setInterval(() => {
    G.m[id].cd--;
    if(G.m[id].cd <= 0) { G.m[id].cd = G.m[id].sec; go(id); }
    draw(id);
  }, 1000);
  updUI();
}

function rm(id) {
  if(G.m[id]) clearInterval(G.m[id].ci);
  delete G.m[id];
  const el = document.getElementById('c'+id); if(el) el.remove();
  updUI(); updStats();
}

function handleAdd() {
  const v = document.getElementById('inp').value;
  const m = v.match(/MLA-?\d+/gi);
  if(m) m.forEach(id => add(id.replace('-','').toUpperCase()));
  document.getElementById('inp').value = '';
}

function updUI() {
  const n = Object.keys(G.m).length;
  document.getElementById('empty').style.display = n ? 'none' : 'block';
  document.getElementById('lpill').className = n ? 'lpill' : 'lpill hidden';
  document.getElementById('ln').textContent = n + ' activos';
  document.getElementById('stopBtn').className = n ? 'sdng' : 'sdng hidden';
}

function updStats() {
  const vals = Object.values(G.m);
  document.getElementById('tsT').textContent = vals.length;
  document.getElementById('tsU').textContent = vals.filter(x => x.st === 'up').length;
  document.getElementById('tsD').textContent = vals.filter(x => x.st === 'dn').length;
}

function stopAll() { Object.keys(G.m).forEach(rm); }
function iCh() { G.sec = parseInt(document.getElementById('isel').value); }

// EXCEL SIMPLE
function xSel(e) {
  const f = e.target.files[0];
  const r = new FileReader();
  r.onload = (ev) => {
    const wb = XLSX.read(new Uint8Array(ev.target.result), {type:'array'});
    const ids = [];
    wb.SheetNames.forEach(n => {
      const j = XLSX.utils.sheet_to_json(wb.Sheets[n], {header:1});
      j.forEach(row => row.forEach(c => {
        const m = String(c).match(/MLA-?\d+/gi);
        if(m) m.forEach(id => ids.push(id.replace('-','').toUpperCase()));
      }));
    });
    if(ids.length) {
      document.getElementById('xnm').textContent = f.name;
      document.getElementById('xcnt').textContent = ids.length;
      document.getElementById('xprev').className = 'xprev';
      G.pending = ids;
    }
  };
  r.readAsArrayBuffer(f);
}
function xImp() { G.pending.forEach(add); xClr(); }
function xClr() { document.getElementById('xprev').className = 'xprev hidden'; document.getElementById('xf').value=''; }
function dOv(e){e.preventDefault();} function dLv(){} function dDr(e){e.preventDefault(); xSel({target:e.dataTransfer});}

// Test Inicial
window.onload = () => add('MLA1101377918');
</script>
</body>
</html>
